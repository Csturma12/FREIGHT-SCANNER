# Server
PORT=3000

# EIA — https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# FMCSA SAFER / QCMobile — https://mobile.fmcsa.dot.gov/developer/
FMCSA_WEBKEY=

# Tavily — https://tavily.com (DAT trendlines scrape, FMCSA news, Federal Register)
TAVILY_API_KEY=

# NOAA requires a User-Agent identifying the app + a contact email. No API key.
# Format: "freight-scanner/1.0 (you@example.com)"
NOAA_USER_AGENT=

# Morning summary email (sent 6:45 AM via Windows Task Scheduler)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_TO=
